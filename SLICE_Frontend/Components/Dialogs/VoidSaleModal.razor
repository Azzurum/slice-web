@using SLICE_Frontend.Components.Pages
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="void-window" @onclick:stopPropagation="true">
            
            @* CLOSE BUTTON *@
            <button class="btn-close-window" @onclick="Close" title="Close">
                <i class="fa fa-times"></i>
            </button>

            @* HEADER *@
            <div class="d-flex align-items-center mb-4">
                <div class="icon-circle">
                    <i class="fa fa-history"></i>
                </div>
                <div>
                    <div class="header-title">TRANSACTION HISTORY</div>
                    <div class="header-sub">Select a completed sale from today to void and refund.</div>
                </div>
            </div>

            @* DATAGRID AREA *@
            <div class="grid-container">
                <table class="w-100" style="border-collapse: collapse;">
                    <thead>
                        <tr>
                            <th style="width: 130px;">REF ID</th>
                            <th style="width: 100px;">TIME</th>
                            <th>PRODUCT ITEM</th>
                            <th style="width: 80px;">QTY</th>
                            <th style="width: 120px;">AMOUNT</th>
                            <th style="width: 110px;">METHOD</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Transactions == null || Transactions.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted fw-bold">No transactions found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var tx in Transactions)
                            {
                                <tr class="@(SelectedRefNum == tx.ReferenceNumber ? "row-selected" : "row-hover")" 
                                    @onclick="() => SelectTransaction(tx)">
                                    
                                    <td class="fw-bold">@tx.ReferenceNumber</td>
                                    
                                    @* USING THE NEW SMART DISPLAY PROPERTIES HERE! *@
                                    <td style="color: #95A5A6;">@tx.DisplayDate.ToString("hh:mm tt")</td>
                                    <td>@tx.DisplayProduct</td>
                                    <td class="fw-black">@tx.DisplayQty</td>
                                    <td class="fw-bold" style="color: #27AE60;">@tx.DisplayAmount.ToString("C2")</td>
                                    <td style="color: #7F8C8D;">@tx.DisplayMethod</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @* BOTTOM ACTION ROW *@
            <div class="action-row mt-4">
                <div class="reason-col">
                    <div class="reason-lbl">REASON FOR VOID</div>
                    <div class="reason-box">
                        <input type="text" class="reason-input" placeholder="e.g. Customer changed mind, Error in order..." 
                               @bind="VoidReason" @bind:event="oninput" />
                    </div>
                </div>
                <div class="btn-col">
                    <button class="btn-void" @onclick="AttemptVoid">VOID TRANSACTION</button>
                </div>
            </div>

        </div>
    </div>

    @* MANAGER APPROVAL OVERLAY *@
    <ManagerApprovalModal 
        IsVisible="showManagerApproval" 
        IsVisibleChanged="@((bool val) => showManagerApproval = val)" 
        OnAuthorized="ProcessAuthorizedVoid" />
}

<style>
    .modal-overlay {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.56);
        z-index: 10000; display: flex; justify-content: center; align-items: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .void-window {
        width: 1000px; height: 700px; background: white; border-radius: 16px;
        padding: 35px; position: relative; display: flex; flex-direction: column;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    }

    .btn-close-window {
        position: absolute; top: 25px; right: 25px; background: transparent; border: none;
        color: #BDC3C7; font-size: 18px; cursor: pointer; transition: 0.2s; outline: none;
    }
    .btn-close-window:hover { opacity: 0.6; color: #E74C3C; }

    .icon-circle {
        background: #FDEDEC; width: 56px; height: 56px; border-radius: 28px;
        display: flex; justify-content: center; align-items: center; margin-right: 20px;
    }
    .icon-circle i { color: #E74C3C; font-size: 24px; }
    .header-title { font-size: 24px; font-weight: 900; color: #2C3E50; line-height: 1.2; }
    .header-sub { font-size: 14px; color: #95A5A6; }

    .grid-container {
        flex-grow: 1; border: 1px solid #EAECEE; border-radius: 8px;
        background: #FAFCFC; padding: 10px; overflow-y: auto;
    }
    th {
        color: #7F8C8D; font-size: 13px; font-weight: bold;
        padding: 12px; border-bottom: 1px solid #EAECEE; text-align: left;
    }
    td { padding: 15px 12px; border-bottom: 1px solid #F4F6F6; font-size: 15px;}
    
    .row-hover { cursor: pointer; transition: 0.1s; }
    .row-hover:hover { background: #F0F3F4; }
    
    .row-selected { background: #FDEDEC !important; cursor: pointer; }
    .row-selected td { color: #C0392B !important; }

    .action-row { display: grid; grid-template-columns: 1fr 250px; gap: 25px; align-items: flex-end; }
    .reason-lbl { font-size: 12px; font-weight: bold; color: #7F8C8D; margin-bottom: 8px; }
    .reason-box {
        background: #F8F9FA; border: 1.5px solid #EAECEE; border-radius: 8px;
        height: 50px; display: flex; align-items: center; padding: 0 15px; width: 100%;
    }
    .reason-input { border: none; background: transparent; width: 100%; font-size: 16px; color: #2C3E50; outline: none; }
    
    .btn-void {
        background: #E74C3C; color: white; font-weight: bold; font-size: 15px;
        border: none; border-radius: 8px; height: 50px; width: 100%;
        cursor: pointer; transition: 0.2s; outline: none;
        box-shadow: 0 4px 15px rgba(231, 76, 60, 0.3);
    }
    .btn-void:hover { opacity: 0.85; }
    .btn-void:active { opacity: 0.7; }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public List<POS.TransactionDto> Transactions { get; set; } = new();
    [Parameter] public EventCallback<POS.VoidRequestPayload> OnVoidConfirmed { get; set; }

    private string SelectedRefNum = "";
    private string SelectedStatus = "";
    private string VoidReason = "";
    private bool showManagerApproval = false;

    private void SelectTransaction(POS.TransactionDto tx)
    {
        SelectedRefNum = tx.ReferenceNumber;
        SelectedStatus = tx.Status;
    }

    private async Task AttemptVoid()
    {
        if (string.IsNullOrEmpty(SelectedRefNum))
        {
            await JS.InvokeVoidAsync("alert", "Please select a transaction to void.");
            return;
        }

        if (SelectedStatus == "Voided")
        {
            await JS.InvokeVoidAsync("alert", "This transaction is already voided.");
            return;
        }

        if (string.IsNullOrWhiteSpace(VoidReason))
        {
            await JS.InvokeVoidAsync("alert", "You must provide a reason for voiding this transaction.");
            return;
        }

        // Trigger the Manager Auth window
        showManagerApproval = true;
    }

    private async Task ProcessAuthorizedVoid(int managerId)
    {
        showManagerApproval = false;

        var payload = new POS.VoidRequestPayload
        {
            ReferenceNumber = SelectedRefNum,
            Reason = VoidReason,
            ManagerID = managerId
        };

        await OnVoidConfirmed.InvokeAsync(payload);
        await Close(); 
    }

    private async Task Close()
    {
        SelectedRefNum = "";
        VoidReason = "";
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }
}