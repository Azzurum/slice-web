@inject HttpClient Http
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Cancel">
        <div class="modal-window" @onclick:stopPropagation="true">
            <button class="btn-close" @onclick="Cancel" title="Close"><i class="fa fa-times"></i></button>

            <div class="modal-padding">
                
                @* HEADER *@
                <div class="header-stack">
                    <div class="icon-circle">
                        <i class="fa fa-shield"></i>
                    </div>
                    <div class="title">ACCOUNT RECOVERY</div>
                </div>

                @* STEP 1: EMAIL *@
                @if (currentStep == 1)
                {
                    <div class="step-panel">
                        <div class="instruction-text">Enter your registered email address. We will send you a 6-digit verification code.</div>
                        
                        <div class="input-lbl">EMAIL ADDRESS</div>
                        <div class="input-border">
                            <i class="fa fa-envelope-o input-icon"></i>
                            <input type="email" class="clean-input" @bind="Email" />
                        </div>

                        <button class="btn-primary bg-orange shadow-orange" @onclick="SendCode" disabled="@isProcessing">
                            @if (isProcessing) { <i class="fa fa-spinner fa-spin"></i> } else { <span>SEND VERIFICATION CODE</span> }
                        </button>
                    </div>
                }

                @* STEP 2: VERIFY CODE *@
                @if (currentStep == 2)
                {
                    <div class="step-panel">
                        <div class="instruction-text">Check your inbox. Enter the 6-digit security code sent to your email.</div>
                        
                        <div class="input-lbl">SECURITY CODE</div>
                        <div class="input-border">
                            <i class="fa fa-lock input-icon"></i>
                            <input type="text" maxlength="6" class="clean-input code-input" @bind="SecurityCode" />
                        </div>

                        <button class="btn-primary bg-green shadow-green" @onclick="VerifyCode" disabled="@isProcessing">
                            @if (isProcessing) { <i class="fa fa-spinner fa-spin"></i> } else { <span>VERIFY CODE</span> }
                        </button>
                    </div>
                }

                @* STEP 3: RESET PASSWORD *@
                @if (currentStep == 3)
                {
                    <div class="step-panel">
                        <div class="instruction-text success-text">Verification successful! Please create a new secure password for your account.</div>
                        
                        <div class="input-lbl">NEW PASSWORD</div>
                        <div class="input-border">
                            <i class="fa fa-key input-icon"></i>
                            <input type="password" class="clean-input" @bind="NewPassword" />
                        </div>

                        <button class="btn-primary bg-dark shadow-dark" @onclick="ResetPassword" disabled="@isProcessing">
                            @if (isProcessing) { <i class="fa fa-spinner fa-spin"></i> } else { <span>UPDATE PASSWORD</span> }
                        </button>
                    </div>
                }

            </div>
        </div>
    </div>
}

<style>
    /* OVERLAY - GUARANTEED TO BE ON TOP (99999) */
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.56); z-index: 99999; display: flex; justify-content: center; align-items: center; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    
    /* WINDOW (Width="380", Height="440") */
    .modal-window { width: 380px; height: 440px; background: white; border-radius: 16px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25); display: flex; flex-direction: column; position: relative; }
    
    .btn-close { position: absolute; right: 15px; top: 15px; background: transparent; border: none; color: #BDC3C7; font-size: 16px; cursor: pointer; transition: 0.2s; z-index: 10; outline: none; }
    .btn-close:hover { opacity: 0.6; }

    .modal-padding { padding: 30px 35px; display: flex; flex-direction: column; height: 100%; }

    /* HEADER */
    .header-stack { display: flex; flex-direction: column; align-items: center; margin-bottom: 20px; }
    .icon-circle { background: #FFF3E0; width: 64px; height: 64px; border-radius: 32px; display: flex; justify-content: center; align-items: center; color: #E67E22; font-size: 28px; margin-bottom: 15px; }
    .title { font-size: 20px; font-weight: 900; color: #2C3E50; text-align: center; } /* Black */

    /* STEP PANELS */
    .step-panel { display: flex; flex-direction: column; justify-content: flex-end; flex-grow: 1; height: 220px; animation: fadeIn 0.3s ease; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    
    .instruction-text { font-size: 13px; color: #7F8C8D; text-align: center; margin-bottom: 20px; line-height: 1.4; }
    .success-text { color: #27AE60; font-weight: 600; } /* SemiBold */

    /* INPUTS */
    .input-lbl { font-size: 11px; font-weight: 700; color: #7F8C8D; margin-bottom: 6px; }
    .input-border { background: #F8F9FA; border: 1.5px solid #EAECEE; border-radius: 8px; height: 45px; display: grid; grid-template-columns: 45px 1fr; align-items: center; margin-bottom: 20px; }
    .input-icon { color: #BDC3C7; font-size: 16px; justify-self: center; }
    
    .clean-input { background: transparent; border: none; outline: none; font-size: 15px; color: #2C3E50; width: 100%; padding-right: 15px; }
    .code-input { font-size: 22px; font-weight: 900; text-align: center; color: #E74C3C; padding: 0 45px 0 0; letter-spacing: 5px; }

    /* MODERN BUTTONS */
    .btn-primary { color: white; height: 45px; border-radius: 8px; border: none; font-weight: 700; cursor: pointer; transition: 0.2s; width: 100%; outline: none; }
    .btn-primary:hover:not(:disabled) { opacity: 0.85; transform: translateY(-1px); }
    .btn-primary:active:not(:disabled) { opacity: 0.7; transform: translateY(1px); box-shadow: none !important; }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    
    .bg-orange { background: #E67E22; }
    .shadow-orange { box-shadow: 0 2px 10px rgba(230, 126, 34, 0.3); }

    .bg-green { background: #27AE60; }
    .shadow-green { box-shadow: 0 2px 10px rgba(39, 174, 96, 0.3); }

    .bg-dark { background: #2C3E50; }
    .shadow-dark { box-shadow: 0 2px 10px rgba(44, 62, 80, 0.3); }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }

    private int currentStep = 1;
    private bool isProcessing = false;
    
    private string Email = "";
    private string SecurityCode = "";
    private string NewPassword = "";

    protected override void OnParametersSet()
    {
        if (IsVisible && currentStep == 3 && string.IsNullOrEmpty(Email))
        {
            // Reset if reopened from scratch
            currentStep = 1;
        }
    }

    private async Task SendCode()
    {
        if (string.IsNullOrWhiteSpace(Email)) return;
        isProcessing = true;

        try 
        {
            var response = await Http.PostAsJsonAsync("api/auth/forgot-password", new { Email });
            if (response.IsSuccessStatusCode)
            {
                currentStep = 2;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Failed: {error}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Network Error: Make sure your backend API is running.");
        }
        
        isProcessing = false;
        StateHasChanged();
    }

    private async Task VerifyCode()
    {
        if (string.IsNullOrWhiteSpace(SecurityCode)) return;
        isProcessing = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/verify-code", new { Email = Email, Code = SecurityCode });
            if (response.IsSuccessStatusCode)
            {
                currentStep = 3;
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Invalid or expired code.");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Network Error: Make sure your backend API is running.");
        }
        
        isProcessing = false;
        StateHasChanged();
    }

    private async Task ResetPassword()
    {
        if (string.IsNullOrWhiteSpace(NewPassword)) return;

        // Exact Regex from WPF C#
        var regex = new System.Text.RegularExpressions.Regex(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}$");
        if (!regex.IsMatch(NewPassword))
        {
            await JS.InvokeVoidAsync("alert", "Password must be at least 8 characters long and contain at least one uppercase letter, one lowercase letter, and one number.");
            return;
        }

        isProcessing = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/reset-password", new { Email = Email, NewPassword = NewPassword });
            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "Password successfully updated! You can now log in.");
                await CloseModal();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Failed to reset password.");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Network Error: Make sure your backend API is running.");
        }
        
        isProcessing = false;
        StateHasChanged();
    }

    private async Task Cancel() => await CloseModal();

    private async Task CloseModal()
    {
        IsVisible = false;
        currentStep = 1;
        Email = "";
        SecurityCode = "";
        NewPassword = "";
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }
}