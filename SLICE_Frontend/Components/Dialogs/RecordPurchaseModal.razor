@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="procurement-modal-overlay" @onclick="Cancel">
        <div class="procurement-modal-window" @onclick:stopPropagation="true">
            
            @* 1. HEADER (Matches WPF Grid Row 0) *@
            <div class="proc-header">
                <div class="proc-header-text">
                    <div class="proc-title">New Procurement</div>
                    <div class="proc-subtitle">Record purchased bulk stock and log the vendor expense.</div>
                </div>
                <div class="proc-dest-badge">
                    <i class="fa fa-building" style="margin-right: 8px;"></i>
                    DESTINATION: CENTRAL WAREHOUSE
                </div>
            </div>

            @* 2. MAIN CARD (Matches WPF Grid Row 1) *@
            <div class="proc-main-card">
                
                @* Info Banner *@
                <div class="proc-info-banner">
                    <i class="fa fa-info-circle proc-info-icon"></i>
                    <div>
                        <div class="proc-info-title">Bulk Entry Mode Active</div>
                        <div class="proc-info-desc">Enter your quantities in Bulk Units (e.g., 1 Sack, 5 Cases). The system will automatically calculate the unit cost and convert it into Base Units (grams/ml) for your inventory.</div>
                    </div>
                </div>

                @* Vendor & Date Grid (Matches WPF 1fr / 20 / 220px) *@
                <div class="proc-vendor-grid">
                    <div class="d-flex flex-column">
                        <label class="proc-lbl">SUPPLIER / VENDOR NAME</label>
                        <input type="text" class="proc-input" @bind="SupplierName" />
                    </div>
                    <div class="d-flex flex-column">
                        <label class="proc-lbl">INVOICE DATE</label>
                        <input type="date" class="proc-input" @bind="PurchaseDate" />
                    </div>
                </div>

                <div class="proc-separator"></div>

                @* DataGrid (Matches WPF DataGrid exact dimensions) *@
                <div class="proc-table-container">
                    <table class="proc-table">
                        <colgroup>
                            <col style="width: auto;" />       @* RAW INGREDIENT (Takes remaining space) *@
                            <col style="width: 100px;" />      @* BULK QTY *@
                            <col style="width: 170px;" />      @* PRICE PER BULK UNIT *@
                            <col style="width: 130px;" />      @* SUBTOTAL *@
                            <col style="width: 60px;" />       @* TRASH ICON *@
                        </colgroup>
                        <thead>
                            <tr>
                                <th>RAW INGREDIENT</th>
                                <th style="text-align: center;">BULK QTY</th>
                                <th style="text-align: right; padding-right: 15px;">PRICE PER BULK UNIT (₱)</th>
                                <th style="text-align: right; padding-right: 10px;">SUBTOTAL</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in CartItems)
                            {
                                <tr>
                                    <td>
                                        <select class="proc-grid-input text-dark fw-bold px-2" @bind="item.ItemID">
                                            <option value="0" disabled>Select Ingredient...</option>
                                            @foreach(var ing in AllIngredients)
                                            {
                                                <option value="@ing.ItemID">@ing.ItemName</option>
                                            }
                                        </select>
                                    </td>
                                    <td style="padding: 8px 5px;">
                                        <input type="number" min="0" step="any" class="proc-grid-input text-center fw-black" style="color: #2980B9;" @bind="item.Quantity" @bind:event="oninput" title="Enter amount in Bulk" />
                                    </td>
                                    <td style="padding: 8px 5px;">
                                        <input type="number" min="0" step="any" class="proc-grid-input text-end fw-bold pe-3" style="color: #E67E22;" @bind="item.UnitPrice" @bind:event="oninput" />
                                    </td>
                                    <td class="text-end fw-black pe-3" style="color: #27AE60; font-size: 15px;">
                                        @item.Subtotal.ToString("N2")
                                    </td>
                                    <td class="text-center">
                                        <button class="proc-btn-remove" @onclick="() => RemoveRow(item)">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    
                    <button class="proc-btn-add" @onclick="AddRow">
                        <i class="fa fa-plus-circle" style="margin-right: 8px;"></i> ADD ANOTHER ITEM
                    </button>
                </div>

            </div>

            @* 3. FOOTER (Matches WPF Grid Row 2) *@
            <div class="proc-footer">
                <button class="proc-btn-cancel" @onclick="Cancel">CANCEL</button>
                
                <div class="proc-footer-right">
                    <div class="proc-total-box">
                        <div class="proc-total-lbl">GRAND TOTAL</div>
                        <div class="proc-total-val">₱ @GrandTotal.ToString("N2")</div>
                    </div>
                    <button class="proc-btn-save" @onclick="SavePurchase">
                        <i class="fa fa-check" style="margin-right: 10px;"></i> CONFIRM PURCHASE
                    </button>
                </div>
            </div>

        </div>
    </div>
}

<style>
    /* Reset all box sizing inside this component so inputs don't bulge out */
    .procurement-modal-overlay * { box-sizing: border-box; }

    /* OVERLAY & EXACT WPF DIMENSIONS */
    .procurement-modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.4); z-index: 9999; display: flex; justify-content: center; align-items: center; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .procurement-modal-window { width: 950px; height: 740px; background: #F4F6F7; border-radius: 8px; display: flex; flex-direction: column; padding: 25px 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }

    /* HEADER */
    .proc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .proc-header-text { display: flex; flex-direction: column; }
    .proc-title { font-size: 28px; font-weight: 900; color: #2C3E50; }
    .proc-subtitle { font-size: 14px; color: #7F8C8D; margin-top: 2px; }
    .proc-dest-badge { background: #E8F8F5; border: 1px solid #1ABC9C; border-radius: 8px; padding: 8px 15px; color: #16A085; font-weight: 700; font-size: 12px; display: flex; align-items: center; height: 35px; }

    /* MAIN CARD */
    .proc-main-card { background: white; border-radius: 16px; padding: 25px; box-shadow: 0 4px 20px rgba(189, 195, 199, 0.2); flex-grow: 1; display: flex; flex-direction: column; min-height: 0; }
    
    .proc-info-banner { background: #FEF5E7; border: 1px solid #F39C12; border-radius: 8px; padding: 15px; display: flex; align-items: center; margin-bottom: 20px; }
    .proc-info-icon { font-size: 20px; color: #E67E22; margin-right: 15px; }
    .proc-info-title { font-weight: 900; font-size: 13px; color: #D35400; }
    .proc-info-desc { font-size: 12px; color: #D35400; margin-top: 2px; line-height: 1.4; }

    /* VENDOR GRID: This forces the Supplier input to stretch (1fr) and Date to stay fixed (220px) */
    .proc-vendor-grid { display: grid; grid-template-columns: 1fr 220px; gap: 20px; margin-bottom: 20px; }
    .proc-lbl { font-size: 11px; font-weight: 700; color: #95A5A6; margin-bottom: 6px; }
    .proc-input { background: #F8F9F9; border: 1px solid #EAECEE; border-radius: 8px; height: 42px; width: 100%; padding: 0 15px; font-size: 15px; font-weight: 600; color: #2C3E50; outline: none; }
    .proc-input:focus { border-color: #BDC3C7; background: white; }

    .proc-separator { height: 1px; background: #EEEEEE; margin-bottom: 15px; }

    /* DATAGRID: table-layout: fixed is critical to stop squashing */
    .proc-table-container { overflow-y: auto; overflow-x: hidden; flex-grow: 1; min-height: 0; padding-right: 5px; }
    .proc-table-container::-webkit-scrollbar { width: 6px; }
    .proc-table-container::-webkit-scrollbar-thumb { background: #BDC3C7; border-radius: 3px; }
    
    .proc-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
    .proc-table th { padding: 0 5px 10px 5px; font-weight: 700; color: #95A5A6; border-bottom: 1px solid #EAECEE; font-size: 11px; }
    .proc-table tr { height: 55px; border-bottom: 1px solid #F4F6F7; }
    .proc-table tbody tr:nth-child(even) { background-color: #FAFCFC; }
    .proc-table td { padding: 5px 10px; vertical-align: middle; }

    /* INNER TABLE INPUTS (Matches WPF DataGridCell Border) */
    .proc-grid-input { background: #F8F9F9; border: 1px solid #EAECEE; border-radius: 6px; height: 38px; width: 100%; outline: none; font-size: 14px; }
    .proc-grid-input:focus { border-color: #BDC3C7; background: white; }
    
    .proc-btn-remove { background: transparent; border: none; color: #E74C3C; font-size: 15px; cursor: pointer; transition: 0.2s; padding: 5px; }
    .proc-btn-remove:hover { opacity: 0.7; transform: scale(1.1); }

    /* ADD BUTTON (Matches WPF SoftButtonStyle AliceBlue) */
    .proc-btn-add { background: #F0F8FF; color: #2980B9; border: none; border-radius: 6px; height: 45px; width: 100%; font-weight: 700; font-size: 13px; cursor: pointer; transition: 0.2s; margin-top: 15px; display: flex; justify-content: center; align-items: center; }
    .proc-btn-add:hover { background: #E1F0FA; }

    /* FOOTER */
    .proc-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 25px; }
    .proc-btn-cancel { background: transparent; border: none; color: #95A5A6; font-weight: 700; font-size: 14px; cursor: pointer; width: 100px; text-align: left; outline: none; }
    .proc-btn-cancel:hover { color: #2C3E50; }
    
    .proc-footer-right { display: flex; align-items: center; }
    .proc-total-box { margin-right: 35px; text-align: right; }
    .proc-total-lbl { font-size: 12px; font-weight: 700; color: #95A5A6; margin-bottom: 2px; }
    .proc-total-val { font-size: 32px; font-weight: 900; color: #E67E22; line-height: 1; margin-top: -5px; }
    
    .proc-btn-save { background: #27AE60; color: white; border: none; border-radius: 8px; width: 240px; height: 55px; font-size: 15px; font-weight: 700; cursor: pointer; transition: 0.2s; display: flex; justify-content: center; align-items: center; outline: none; }
    .proc-btn-save:hover { opacity: 0.9; }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public EventCallback<PurchasePayload> OnSaved { get; set; }

    [Parameter] public List<IngredientDto> AllIngredients { get; set; } = new();
    [Parameter] public List<PurchaseItemDto> CartItems { get; set; } = new();

    private string SupplierName = "";
    private DateTime PurchaseDate = DateTime.Now;

    private decimal GrandTotal => CartItems.Sum(x => x.Subtotal);

    protected override void OnParametersSet()
    {
        if (IsVisible && CartItems.Count == 0)
        {
            AddRow();
        }
    }

    private void AddRow() => CartItems.Add(new PurchaseItemDto());
    private void RemoveRow(PurchaseItemDto item) => CartItems.Remove(item);

    private async Task SavePurchase()
    {
        if (string.IsNullOrWhiteSpace(SupplierName))
        {
            await JS.InvokeVoidAsync("alert", "Supplier / Vendor Name is required.");
            return;
        }

        if (CartItems.Count == 0 || !CartItems.Any(i => i.Quantity > 0))
        {
            await JS.InvokeVoidAsync("alert", "You must enter at least one item with a quantity greater than zero.");
            return;
        }

        if (CartItems.Any(i => i.Quantity < 0 || i.UnitPrice < 0))
        {
            await JS.InvokeVoidAsync("alert", "Quantities and Prices cannot be negative.");
            return;
        }

        var payload = new PurchasePayload
        {
            SupplierName = SupplierName,
            PurchaseDate = PurchaseDate,
            Items = CartItems.Where(i => i.Quantity > 0 && i.ItemID > 0).ToList(),
            GrandTotal = GrandTotal
        };

        await OnSaved.InvokeAsync(payload);
        await CloseModal();
    }

    private async Task Cancel() => await CloseModal();

    private async Task CloseModal()
    {
        IsVisible = false;
        SupplierName = "";
        PurchaseDate = DateTime.Now;
        CartItems.Clear();
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    // DTOs
    public class IngredientDto { public int ItemID { get; set; } public string ItemName { get; set; } = ""; }
    
    public class PurchaseItemDto 
    { 
        public int ItemID { get; set; } 
        public decimal Quantity { get; set; } 
        public decimal UnitPrice { get; set; } 
        public decimal Subtotal => Quantity * UnitPrice; 
    }

    public class PurchasePayload
    {
        public string SupplierName { get; set; } = "";
        public DateTime PurchaseDate { get; set; }
        public List<PurchaseItemDto> Items { get; set; } = new();
        public decimal GrandTotal { get; set; }
    }
}