@using System.Threading
@inject IJSRuntime JS

<div class="modal-overlay" @onclick="Cancel">
    <div class="gateway-window shadow-hard" @onclick:stopPropagation="true">
        
        @* LEFT PANEL (Dark Theme) *@
        <div class="gateway-left">
            <div class="lock-icon-box">
                <i class="fa fa-lock"></i>
            </div>
            
            <div class="lbl-total">TOTAL AMOUNT DUE</div>
            <div class="val-total">@TotalAmount.ToString("C2")</div>
            
            <div class="separator-line"></div>
            
            <div class="brand-name">S.L.I.C.E. ENTERPRISE</div>
            <div class="brand-sub">Payment Gateway Integration</div>
            <div class="brand-version">v2.5 Secured Transaction</div>
        </div>

        @* RIGHT PANEL (Dynamic Content) *@
        <div class="gateway-right">
            <button class="btn-close" @onclick="Cancel"><i class="fa fa-times"></i></button>

            @* 1. SELECTION VIEW *@
            @if (CurrentView == 0)
            {
                <div class="view-container">
                    <div class="view-title">Select Payment Method</div>
                    <div class="view-subtitle">Choose how the customer will settle the balance.</div>

                    <div class="method-grid">
                        <button class="btn-method" @onclick="@(() => SelectMethod("Cash"))">
                            <i class="fa fa-money-bill-wave text-success mb-2" style="font-size: 28px;"></i>
                            <div>Physical Cash</div>
                        </button>
                        <button class="btn-method" @onclick="@(() => SelectMethod("Credit / Debit Card"))">
                            <i class="fa fa-credit-card text-primary mb-2" style="font-size: 26px;"></i>
                            <div>Card Payment</div>
                        </button>
                        <button class="btn-method" @onclick="@(() => SelectMethod("GCash"))">
                            <i class="fa fa-mobile text-info mb-2" style="font-size: 32px;"></i>
                            <div>GCash e-Wallet</div>
                        </button>
                        <button class="btn-method" @onclick="@(() => SelectMethod("Maya"))">
                            <i class="fa fa-check-circle text-success mb-2" style="font-size: 26px;"></i>
                            <div>PayMaya</div>
                        </button>
                    </div>
                </div>
            }

            @* 2. INPUT VIEW *@
            @if (CurrentView == 1)
            {
                <div class="view-container">
                    <button class="btn-back" @onclick="GoBack">
                        <i class="fa fa-angle-left me-2"></i> Change Payment Method
                    </button>

                    <div class="view-title mb-4">@SelectedMethod</div>

                    @if (IsCardPayment)
                    {
                        <div class="card-prompt-box">
                            <i class="fa fa-credit-card-alt mb-3" style="font-size: 45px; color: #34495E;"></i>
                            <div class="fw-black fs-5 text-dark mb-2">AWAITING CARD TERMINAL</div>
                            <div class="text-muted text-center" style="font-size: 13px; max-width: 280px;">
                                Please ask the customer to tap or insert their card on the physical terminal.
                            </div>
                        </div>
                    }

                    @if (IsCashPayment)
                    {
                        <div class="w-100">
                            <div class="lbl-input">AMOUNT TENDERED (₱)</div>
                            <div class="cash-input-box">
                                <input type="number" class="cash-input" @bind="AmountTendered" @bind:event="oninput" min="0" step="any" />
                            </div>

                            <div class="lbl-input">CHANGE DUE</div>
                            <div class="change-val text-dark mb-4">@ChangeAmount.ToString("C2")</div>
                        </div>
                    }

                    @if (IsEwalletPayment)
                    {
                        <div class="qr-prompt-box">
                            <img src="@QrUrl" class="qr-image mb-3" />
                            <div class="fw-black fs-5 text-dark">AWAITING CUSTOMER SCAN</div>
                        </div>
                    }

                    <button class="btn-confirm w-100" @onclick="ProcessPayment" disabled="@(IsCashPayment && AmountTendered < TotalAmount)">
                        CONFIRM & COMPLETE TRANSACTION
                    </button>
                </div>
            }

            @* 3. PROCESSING VIEW *@
            @if (CurrentView == 2)
            {
                <div class="view-container align-items-center justify-content-center text-center">
                    <i class="fa fa-circle-o-notch fa-spin text-primary mb-4" style="font-size: 50px;"></i>
                    <div class="fw-black fs-4 text-dark">@ProcessingMessage</div>
                </div>
            }

            @* 4. RESULT VIEW *@
            @if (CurrentView == 3)
            {
                <div class="view-container align-items-center justify-content-center text-center">
                    @if (IsSuccess)
                    {
                        <i class="fa fa-check-circle text-success mb-4" style="font-size: 90px;"></i>
                        <div class="fw-black fs-3 text-dark mb-2">@ResultMessage</div>
                        <div class="fw-bold text-muted fs-6">System Trace ID: @ReferenceNumber</div>
                    }
                    else
                    {
                        <i class="fa fa-times-circle text-danger mb-4" style="font-size: 90px;"></i>
                        <div class="fw-black fs-3 text-dark mb-2">@ResultMessage</div>
                        <button class="btn-back mt-4" @onclick="GoBack">Try Again</button>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.55); z-index: 10000; display: flex; justify-content: center; align-items: center; font-family: 'Segoe UI', sans-serif; }
    .gateway-window { width: 900px; height: 640px; background: white; border-radius: 20px; display: grid; grid-template-columns: 340px 1fr; overflow: hidden; }
    .shadow-hard { box-shadow: 0 15px 40px rgba(0,0,0,0.3); }

    /* LEFT PANEL */
    .gateway-left { background: #1A252F; padding: 35px; display: flex; flex-direction: column; justify-content: center; }
    .lock-icon-box { background: #2C3E50; width: 70px; height: 70px; border-radius: 35px; display: flex; justify-content: center; align-items: center; color: #ecf0f1; font-size: 28px; margin-bottom: 25px; }
    .lbl-total { color: #95A5A6; font-size: 12px; font-weight: 900; margin-bottom: 5px; }
    .val-total { color: white; font-weight: 900; font-size: 44px; margin-bottom: 30px; line-height: 1; }
    .separator-line { height: 1px; background: #34495E; margin-bottom: 30px; }
    .brand-name { color: #BDC3C7; font-size: 14px; font-weight: 900; }
    .brand-sub { color: #7F8C8D; font-size: 12px; margin-top: 5px; }
    .brand-version { color: #34495E; font-size: 10px; font-weight: 700; margin-top: 20px; }

    /* RIGHT PANEL */
    .gateway-right { padding: 40px 30px; position: relative; display: flex; flex-direction: column; }
    .btn-close { position: absolute; top: 20px; right: 20px; background: transparent; border: none; color: #BDC3C7; font-size: 18px; cursor: pointer; transition: 0.2s; outline: none; }
    .btn-close:hover { color: #E74C3C; }

    .view-container { display: flex; flex-direction: column; flex-grow: 1; justify-content: center; }
    .view-title { font-size: 26px; font-weight: 900; color: #2C3E50; margin-bottom: 10px; }
    .view-subtitle { font-size: 14px; color: #95A5A6; margin-bottom: 30px; }

    .method-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .btn-method { background: #FDFDFD; border: 2px solid #E0E6ED; border-radius: 12px; height: 90px; display: flex; flex-direction: column; justify-content: center; align-items: center; color: #2C3E50; font-weight: 700; font-size: 16px; cursor: pointer; transition: 0.2s; outline: none; }
    .btn-method:hover { background: #F0F8FF; border-color: #3498DB; color: #2980B9; }

    .btn-back { background: transparent; border: none; color: #7F8C8D; font-weight: 700; font-size: 13px; align-self: flex-start; padding: 0; margin-bottom: 25px; cursor: pointer; outline: none; }
    .btn-back:hover { color: #2C3E50; }

    .lbl-input { font-size: 12px; font-weight: 700; color: #95A5A6; margin-bottom: 10px; }
    .cash-input-box { background: #F8F9FA; border: 2px solid #E0E6ED; border-radius: 10px; height: 75px; margin-bottom: 25px; display: flex; align-items: center; padding: 0 20px; }
    .cash-input { border: none; background: transparent; font-size: 36px; font-weight: 900; color: #27AE60; width: 100%; outline: none; }
    .change-val { font-size: 48px; font-weight: 900; line-height: 1; }

    .card-prompt-box, .qr-prompt-box { background: #F8F9FA; border: 1px solid #E0E6ED; border-radius: 12px; padding: 30px; margin-bottom: 25px; display: flex; flex-direction: column; align-items: center; }
    .qr-image { width: 180px; height: 180px; }

    .btn-confirm { background: #27AE60; color: white; height: 60px; border: none; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer; transition: 0.2s; box-shadow: 0 5px 20px rgba(39, 174, 96, 0.4); outline: none; }
    .btn-confirm:hover:not(:disabled) { opacity: 0.9; transform: translateY(-2px); }
    .btn-confirm:disabled { background: #BDC3C7; box-shadow: none; cursor: not-allowed; }

    .fw-black { font-weight: 900; }
</style>

@code {
    [Parameter] public decimal TotalAmount { get; set; }
    [Parameter] public EventCallback<PaymentResult> OnPaymentComplete { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private int CurrentView = 0; // 0=Selection, 1=Input, 2=Processing, 3=Result
    private string SelectedMethod = "";
    private string ReferenceNumber = "";
    private string QrUrl = "";

    private decimal amountTendered;
    private decimal AmountTendered
    {
        get => amountTendered;
        set { amountTendered = value; }
    }
    private decimal ChangeAmount => AmountTendered >= TotalAmount ? AmountTendered - TotalAmount : 0;

    private bool IsCardPayment => SelectedMethod == "Credit / Debit Card";
    private bool IsCashPayment => SelectedMethod == "Cash";
    private bool IsEwalletPayment => SelectedMethod == "GCash" || SelectedMethod == "Maya";

    private string ProcessingMessage = "";
    private string ResultMessage = "";
    private bool IsSuccess = false;
    private bool _isClosing = false;

    private void SelectMethod(string method)
    {
        SelectedMethod = method;
        CurrentView = 1; // Go to input view
        AmountTendered = 0;

        // 1. GENERATE REFERENCE NUMBER UPFRONT
        ReferenceNumber = $"TXN-{DateTime.Now.Ticks.ToString().Substring(8)}-{new Random().Next(10, 99)}";

        // 2. GENERATE QR CODE URL
        if (IsEwalletPayment)
        {
            string methodUrlFriendly = SelectedMethod.Replace(" ", "").Replace("/", "").ToLower();
            string baseUrl = "https://azzurum.github.io/slice-pay/";
            string qrText = $"{baseUrl}?method={methodUrlFriendly}&amount={TotalAmount:F2}&ref={ReferenceNumber}";
            
            // Map to live QR Generator API
            QrUrl = $"https://api.qrserver.com/v1/create-qr-code/?size=200x200&data={Uri.EscapeDataString(qrText)}";
        }
    }

    private void GoBack()
    {
        CurrentView = 0;
    }

    private async Task ProcessPayment()
    {
        // 1. CASH PAYMENT
        if (IsCashPayment)
        {
            ReferenceNumber = $"CASH-{DateTime.Now.Ticks.ToString().Substring(8)}";
            ResultMessage = $"Payment Complete. Change: {ChangeAmount:C2}";
            IsSuccess = true;
            CurrentView = 3;
            await FinishAndClose();
            return;
        }

        // 2. DIGITAL & CARD PAYMENT (Exact WPF Simulation Logic)
        CurrentView = 2; // Processing View
        ProcessingMessage = IsCardPayment ? "Awaiting Terminal Response..." : "Awaiting Customer App Confirmation...";
        StateHasChanged();
        await Task.Delay(1500);

        ProcessingMessage = "Authorizing Transaction...";
        StateHasChanged();
        await Task.Delay(1500);

        // 15% chance of realistic random failure
        bool simulateFailure = new Random().Next(1, 100) <= 15;

        CurrentView = 3; // Result View

        if (!simulateFailure)
        {
            IsSuccess = true;
            ResultMessage = "Payment Approved & Secured";
            StateHasChanged();
            await FinishAndClose();
        }
        else
        {
            IsSuccess = false;
            ResultMessage = IsCardPayment ? "Terminal Declined: Insufficient Funds." : "Customer App Declined or Timeout.";
            StateHasChanged();
        }
    }

    private async Task FinishAndClose()
    {
        await Task.Delay(2500);
        await CloseWithResult();
    }

    private async Task CloseWithResult()
    {
        if (_isClosing) return;
        _isClosing = true;

        var result = new PaymentResult
        {
            IsSuccess = IsSuccess,
            PaymentMethod = SelectedMethod,
            ReferenceNumber = ReferenceNumber,
            ErrorMessage = IsSuccess ? null : ResultMessage
        };

        await OnPaymentComplete.InvokeAsync(result);
    }

    private async Task Cancel()
    {
        if (CurrentView == 2) return; // Prevent canceling while processing
        await OnCancel.InvokeAsync();
    }

    public class PaymentResult
    {
        public bool IsSuccess { get; set; }
        public string PaymentMethod { get; set; } = string.Empty;
        public string ReferenceNumber { get; set; } = string.Empty;
        public string? ErrorMessage { get; set; }
    }
}