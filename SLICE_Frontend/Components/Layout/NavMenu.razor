<div class="sidebar-background">
    @* --- THE OVEN GRADIENT --- *@
    <div class="sidebar-oven">

        @* Floating background circles from XAML Canvas triggers *@
        <div class="floating-circle p1"></div>
        <div class="floating-circle p2"></div>

        @* Logo Area (Matches Margin="0,30,0,30" and text styling) *@
        <div class="brand-header">
            <img src="images/Logo.png" class="logo-img" alt="Logo" />
            <h1 class="brand-title">S.L.I.C.E.</h1>
            <p class="brand-subtitle">ENTERPRISE</p>
        </div>

        @* Denly packed Scrollable Navigation *@
        <div class="nav-scrollable">
            <nav class="flex-column">
                
                @* DASHBOARD GROUP *@
                <div class="menu-group mt-2">DASHBOARD</div>
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <div class="icon-container"><i class="fa fa-dashboard icon"></i></div>
                    <span class="text">Overview</span>
                </NavLink>

                @* OPERATIONS GROUP *@
                <div class="menu-group">OPERATIONS</div>
                <NavLink class="nav-link" href="incoming">
                    <div class="icon-container"><i class="fa fa-inbox icon"></i></div>
                    <span class="text">Incoming Orders</span>
                </NavLink>
                <NavLink class="nav-link" href="mystock">
                    <div class="icon-container"><i class="fa fa-cubes icon"></i></div>
                    <span class="text">My Inventory</span>
                </NavLink>
                <NavLink class="nav-link" href="sales">
                    <div class="icon-container"><i class="fa fa-desktop icon"></i></div>
                    <span class="text">Counter</span>
                </NavLink>
                <NavLink class="nav-link" href="waste">
                    <div class="icon-container"><i class="fa fa-trash icon"></i></div>
                    <span class="text">Waste Tracker</span>
                </NavLink>

                @* MANAGEMENT GROUP *@
                <div class="menu-group">MANAGEMENT</div>
                <NavLink class="nav-link" href="inventory">
                    <div class="icon-container"><i class="fa fa-globe icon"></i></div>
                    <span class="text">Central Warehouse</span>
                </NavLink>
                <NavLink class="nav-link" href="finance">
                    <div class="icon-container"><i class="fa fa-line-chart icon"></i></div>
                    <span class="text">Financial Ledger</span>
                </NavLink>
                <NavLink class="nav-link" href="users">
                    <div class="icon-container"><i class="fa fa-users icon"></i></div>
                    <span class="text">Users & Roles</span>
                </NavLink>

            </nav>
        </div>

        @* User Footer (Matches exactly) *@
        <div class="user-footer">
            <div class="user-avatar">U</div>
            <div class="user-info">
                <div class="user-name">User Name</div>
                <div class="user-role">Super-Admin</div>
            </div>
            <button class="btn-logout" title="Sign Out">
                <i class="fa fa-sign-out"></i>
            </button>
        </div>

    </div>
</div>