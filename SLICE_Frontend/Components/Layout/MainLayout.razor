@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using SLICE_Frontend.Auth
@using SLICE_Frontend.Components.Dialogs
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject HttpClient Http

<div class="slice-window">
    
    @* ========================================== *@
    @* SIDEBAR (Grid Column 0: Width="280")       *@
    @* ========================================== *@
    <aside class="slice-sidebar">
        
        @* ANIMATED ORBS (Canvas Canvas.Loaded Storyboard) *@
        <div class="orb-canvas">
            <div class="orb p1-orb"></div>
            <div class="orb p2-orb"></div>
        </div>

        <div class="sidebar-content">
            
            @* LOGO AREA - Click opens About Modal *@
            <button class="logo-btn" @onclick="() => showAboutModal = true" title="About S.L.I.C.E.">
                <div class="logo-stack">
                    <img src="Images/Logo.png" class="logo-img" alt="Logo" onerror="this.style.display='none'" />
                    <div class="logo-text">S.L.I.C.E.</div>
                    <div class="logo-subtext">ENTERPRISE</div>
                </div>
            </button>

            @* SCROLLING MENU (VerticalScrollBarVisibility="Hidden") *@
            <div class="menu-scroll">
                <div class="menu-stack">

                    @* --- DASHBOARD GROUP --- *@
                    <AuthorizeView Roles="Super-Admin,Manager,Logistics Admin">
                        <Authorized>
                            <div class="menu-header">DASHBOARD</div>
                            <NavLink class="menu-btn" href="/" Match="NavLinkMatch.All">
                                <div class="indicator"></div>
                                <div class="menu-grid">
                                    <i class="fa fa-dashboard menu-icon"></i>
                                    <span>Overview</span>
                                </div>
                            </NavLink>
                        </Authorized>
                    </AuthorizeView>

                    @* --- OPERATIONS GROUP --- *@
                    <AuthorizeView Roles="Super-Admin,Manager,Clerk,Logistics Admin">
                        <Authorized>
                            <div class="menu-header">OPERATIONS</div>

                            <AuthorizeView Roles="Manager,Clerk,Logistics Admin" Context="OpsContext">
                                <NavLink class="menu-btn" href="/incoming">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-inbox menu-icon"></i><span>Incoming Orders</span></div>
                                </NavLink>
                            </AuthorizeView>

                            <AuthorizeView Roles="Manager,Clerk" Context="OpsContext">
                                <NavLink class="menu-btn" href="/my-inventory">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-cubes menu-icon"></i><span>My Inventory</span></div>
                                </NavLink>
                                <NavLink class="menu-btn" href="/request-stock">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-shopping-basket menu-icon"></i><span>Request Stock</span></div>
                                </NavLink>
                                <NavLink class="menu-btn" href="/pos">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-desktop menu-icon"></i><span>Counter</span></div>
                                </NavLink>
                            </AuthorizeView>

                            <AuthorizeView Roles="Manager,Logistics Admin" Context="OpsContext">
                                <NavLink class="menu-btn" href="/approve">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-check-square menu-icon"></i><span>Approve Requests</span></div>
                                </NavLink>
                            </AuthorizeView>

                            <AuthorizeView Roles="Super-Admin,Manager,Clerk,Logistics Admin" Context="OpsContext">
                                <NavLink class="menu-btn" href="/waste">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-trash menu-icon"></i><span>Waste Tracker</span></div>
                                </NavLink>
                            </AuthorizeView>

                            <AuthorizeView Roles="Super-Admin,Manager,Logistics Admin" Context="OpsContext">
                                <NavLink class="menu-btn" href="/recon">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-balance-scale menu-icon"></i><span>Reconciliation</span></div>
                                </NavLink>
                            </AuthorizeView>

                            <AuthorizeView Roles="Manager,Clerk,Logistics Admin" Context="OpsContext">
                                <NavLink class="menu-btn" href="/feedback">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-comment menu-icon"></i><span>Submit Feedback</span></div>
                                </NavLink>
                            </AuthorizeView>
                        </Authorized>
                    </AuthorizeView>

                    @* --- MANAGEMENT GROUP --- *@
                    <AuthorizeView Roles="Super-Admin,Logistics Admin">
                        <Authorized>
                            <div class="menu-header">MANAGEMENT</div>

                            <AuthorizeView Roles="Super-Admin" Context="AdminContext">
                                <NavLink class="menu-btn" href="/menu">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-book menu-icon"></i><span>Menu Registry</span></div>
                                </NavLink>
                            </AuthorizeView>

                            <NavLink class="menu-btn" href="/global-inventory">
                                <div class="indicator"></div>
                                <div class="menu-grid"><i class="fa fa-globe menu-icon"></i><span>Central Warehouse</span></div>
                            </NavLink>

                            <AuthorizeView Roles="Super-Admin" Context="AdminContext">
                                <NavLink class="menu-btn" href="/finance">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-line-chart menu-icon"></i><span>Financial Ledger</span></div>
                                </NavLink>
                                <NavLink class="menu-btn" href="/discounts">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-tags menu-icon"></i><span>Manage Discounts</span></div>
                                </NavLink>
                                <NavLink class="menu-btn" href="/users">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-users menu-icon"></i><span>Users & Roles</span></div>
                                </NavLink>
                                <NavLink class="menu-btn" href="/audit">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-history menu-icon"></i><span>Audit Logs</span></div>
                                </NavLink>
                                <NavLink class="menu-btn" href="/review-feedback">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-comments menu-icon"></i><span>Review Feedback</span></div>
                                </NavLink>
                                <NavLink class="menu-btn" href="/settings">
                                    <div class="indicator"></div>
                                    <div class="menu-grid"><i class="fa fa-cogs menu-icon"></i><span>System Settings</span></div>
                                </NavLink>
                            </AuthorizeView>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>

            @* USER BADGE FOOTER (Background="#20000000", Padding="20") *@
            <div class="user-badge">
                <div class="badge-grid">
                    <div class="avatar-circle">
                        <span>@userInitials</span>
                    </div>
                    <div class="user-info">
                        <div class="user-name">@userName</div>
                        <div class="user-role">@userRole</div>
                    </div>
                    <button class="btn-logout" @onclick="Logout" title="Sign Out">
                        <i class="fa fa-sign-out"></i>
                    </button>
                </div>
            </div>

        </div>
    </aside>

    @* ========================================== *@
    @* MAIN CONTENT (Grid Column 1: Width="*")    *@
    @* ========================================== *@
    <main class="slice-main">
        
        @* TOP BAR (Height="60", DropShadowEffect) *@
        <header class="slice-topbar">
            <div class="topbar-grid">
                <div class="page-title">@PageTitle</div>
                <div class="topbar-actions">
                    @* Click opens Manual Modal *@
                    <button class="btn-help" title="System Manual" @onclick="() => showManualModal = true">?</button>
                    <button class="btn-minimize">—</button>
                </div>
            </div>
        </header>

        @* RENDER BODY (MainContentFrame Margin="30", CornerRadius="12") *@
        <div class="slice-content-wrapper">
            <div class="slice-content">
                @Body
            </div>
        </div>

    </main>

    @* ========================================== *@
    @* GLOBAL MODALS                              *@
    @* ========================================== *@
    <UserManualModal IsVisible="showManualModal" IsVisibleChanged="@(val => showManualModal = val)" />
    <AboutModal IsVisible="showAboutModal" IsVisibleChanged="@(val => showAboutModal = val)" />
    <ZReadingModal IsVisible="showZReadingModal" IsVisibleChanged="@(val => showZReadingModal = val)" ExpectedCash="ExpectedCashAmount" OnSubmitLogout="ProcessLogoutWithZReading" />

</div>

<style>
    /* VARIABLES */
    :root {
        --oven-dark: #2C0A06;
        --oven-red: #922B21;
        --pizza-orange: #E67E22;
        --text-ghost: #95A5A6;
        --bg-light: #F4F6F7;
    }

    /* THE MAIN GRID */
    .slice-window {
        display: flex;
        height: 100vh;
        width: 100vw;
        background-color: var(--bg-light);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow: hidden;
    }

    /* --- SIDEBAR --- */
    .slice-sidebar {
        width: 280px;
        height: 100%;
        position: relative;
        flex-shrink: 0;
        /* LinearGradientBrush StartPoint="0,0" EndPoint="1,1" */
        background: linear-gradient(135deg, var(--oven-dark) 0%, var(--oven-red) 100%);
    }

    /* ORB ANIMATIONS (Canvas Setup) */
    .orb-canvas { position: absolute; top: 0; left: 0; right: 0; bottom: 0; overflow: hidden; z-index: 0; pointer-events: none; }
    .orb { position: absolute; border-radius: 50%; }
    
    /* Ellipse P1: Width 150, Fill #E67E22, Left -40, Blur 50 */
    .p1-orb {
        width: 150px; height: 150px; background-color: var(--pizza-orange); left: -40px;
        filter: blur(50px);
        animation: floatP1 25s infinite linear;
    }
    @@keyframes floatP1 {
        0% { top: 1200px; opacity: 0.2; }
        100% { top: -100px; opacity: 0; }
    }

    /* Ellipse P2: Width 80, Fill #F1C40F, Right 30, Blur 30, Delay 5s */
    .p2-orb {
        width: 80px; height: 80px; background-color: #F1C40F; right: 30px; top: 1200px;
        filter: blur(30px);
        animation: floatP2 18s infinite linear 5s;
    }
    @@keyframes floatP2 {
        0% { top: 1200px; opacity: 0.15; }
        100% { top: -100px; opacity: 0; }
    }

    .sidebar-content { position: relative; z-index: 10; display: flex; flex-direction: column; height: 100%; }

    /* LOGO AREA */
    .logo-btn { background: transparent; border: none; padding: 30px 0; cursor: pointer; width: 100%; outline: none; transition: 0.2s; }
    .logo-btn:hover { opacity: 0.8; }
    .logo-stack { display: flex; flex-direction: column; align-items: center; }
    .logo-img { height: 90px; margin-bottom: 10px; filter: drop-shadow(0 0 15px rgba(230, 126, 34, 0.5)); }
    .logo-text { color: white; font-size: 28px; font-weight: 900; } /* FontWeight="Black" */
    .logo-subtext { color: var(--text-ghost); font-size: 11px; font-weight: 700; } /* FontWeight="Bold" */

    /* SCROLLING MENU */
    .menu-scroll { flex-grow: 1; overflow-y: auto; overflow-x: hidden; }
    .menu-scroll::-webkit-scrollbar { display: none; } /* Hidden scrollbar per WPF */
    .menu-stack { padding: 0 10px; display: flex; flex-direction: column; }

    .menu-header { color: var(--text-ghost); font-size: 11px; font-weight: 700; margin: 25px 0 8px 25px; opacity: 0.7; }
    
    /* MENU BUTTON (Style="{StaticResource MenuButtonStyle}") */
    .menu-btn {
        display: flex; align-items: center; height: 50px; margin: 2px 10px; position: relative;
        background: transparent; color: #BDC3C7; font-size: 14px; font-weight: 600; /* SemiBold */
        text-decoration: none; border-radius: 8px; transition: background 0.2s, color 0.2s; cursor: pointer;
    }
    .menu-grid { display: grid; grid-template-columns: 40px 1fr; align-items: center; width: 100%; padding: 0 15px; z-index: 2; }
    .menu-icon { font-size: 16px; color: white; text-align: center; }
    
    /* Active & Hover States */
    .menu-btn:hover, .menu-btn.active { background-color: rgba(255, 255, 255, 0.1); color: white; }
    
    /* Indicator Animation (Rectangle Width="4", Fill="PizzaOrange", ScaleY 0->1) */
    .indicator {
        position: absolute; left: 5px; top: 13px; bottom: 13px; width: 4px;
        background-color: var(--pizza-orange); border-radius: 2px;
        transform: scaleY(0); opacity: 0; transition: transform 0.2s, opacity 0.2s; z-index: 1;
    }
    .menu-btn:hover .indicator, .menu-btn.active .indicator { transform: scaleY(1); opacity: 1; }

    /* FOOTER BADGE (Background="#20000000" Padding="20") */
    .user-badge { background-color: rgba(0, 0, 0, 0.125); padding: 20px; border-top: 1px solid rgba(255,255,255,0.05); }
    .badge-grid { display: grid; grid-template-columns: auto 1fr auto; align-items: center; }
    
    .avatar-circle {
        width: 42px; height: 42px; border-radius: 21px; background-color: var(--pizza-orange);
        color: white; font-weight: 700; font-size: 18px; display: flex; align-items: center; justify-content: center;
    }
    
    .user-info { margin-left: 12px; display: flex; flex-direction: column; justify-content: center; }
    .user-name { color: white; font-weight: 600; font-size: 13px; }
    .user-role { color: var(--text-ghost); font-size: 11px; }
    
    .btn-logout { background: transparent; border: none; color: #E74C3C; font-size: 20px; cursor: pointer; transition: 0.2s; padding: 0; outline: none; }
    .btn-logout:hover { filter: brightness(1.2); }

    /* --- MAIN AREA --- */
    .slice-main { flex-grow: 1; display: flex; flex-direction: column; height: 100%; overflow: hidden; background-color: #F4F6F7; }
    
    /* TOP BAR (Height="60", DropShadowEffect BlurRadius="10") */
    .slice-topbar {
        height: 60px; background-color: white; z-index: 10; padding: 0 30px;
        box-shadow: 0 2px 10px rgba(221, 221, 221, 0.3); display: flex; align-items: center;
    }
    .topbar-grid { display: flex; justify-content: space-between; align-items: center; width: 100%; }
    .page-title { font-size: 22px; font-weight: 700; color: #2C3E50; margin: 0; } /* Bold */
    
    .topbar-actions { display: flex; align-items: center; }
    .btn-help {
        width: 36px; height: 36px; border-radius: 18px; background-color: #F4F6F6;
        border: none; color: #7F8C8D; font-weight: 700; cursor: pointer; margin-right: 20px; transition: 0.2s; outline: none;
    }
    .btn-help:hover { background-color: #EAECEE; color: #2C3E50; }
    
    /* Style="WinBtn" */
    .btn-minimize { background: transparent; border: none; color: #7F8C8D; font-weight: 900; width: 50px; height: 36px; cursor: pointer; transition: 0.2s; outline: none; }
    .btn-minimize:hover { background-color: #EEE; }

    /* RENDER BODY FRAME (Margin="30", CornerRadius="12", DropShadowEffect BlurRadius="20") */
    .slice-content-wrapper { flex-grow: 1; padding: 30px; overflow-y: auto; overflow-x: hidden; }
    .slice-content {
        background-color: white; border-radius: 12px; min-height: 100%; position: relative;
        box-shadow: 0 5px 20px rgba(189, 195, 199, 0.2); overflow: hidden;
    }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private string userName = "Loading...";
    private string userRole = "...";
    private string userInitials = "U";
    private int currentUserId = 0;
    private string PageTitle = "Overview";

    // Global Modal States
    private bool showManualModal = false;
    private bool showAboutModal = false;
    private bool showZReadingModal = false;
    private decimal ExpectedCashAmount = 0m;

    protected override void OnInitialized()
    {
        // Wire up the Navigation Manager to dynamically change the Top Bar title
        Nav.LocationChanged += (s, e) => UpdateTitle(e.Location);
        UpdateTitle(Nav.Uri);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;

        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            userName = user.Identity.Name ?? "Unknown User";
            userRole = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "No Role";
            
            int.TryParse(user.FindFirst("UserID")?.Value, out currentUserId);

            if (!string.IsNullOrEmpty(userName))
            {
                userInitials = userName.Substring(0, 1).ToUpper();
            }
        }
    }

    private void UpdateTitle(string uri)
    {
        if (uri.EndsWith("/")) PageTitle = "Overview";
        else if (uri.EndsWith("/incoming")) PageTitle = "Incoming Deliveries";
        else if (uri.EndsWith("/my-inventory")) PageTitle = "My Branch Inventory";
        else if (uri.EndsWith("/request-stock")) PageTitle = "Stock Requisition";
        else if (uri.EndsWith("/pos")) PageTitle = "Point of Sale";
        else if (uri.EndsWith("/approve")) PageTitle = "Manager Approvals";
        else if (uri.EndsWith("/waste")) PageTitle = "Waste & Loss Tracker";
        else if (uri.EndsWith("/recon")) PageTitle = "Stock Reconciliation";
        else if (uri.EndsWith("/menu")) PageTitle = "Menu Registry";
        else if (uri.EndsWith("/global-inventory")) PageTitle = "Central Warehouse";
        else if (uri.EndsWith("/finance")) PageTitle = "Financial Performance";
        else if (uri.EndsWith("/discounts")) PageTitle = "Pricing & Promotions Rules";
        else if (uri.EndsWith("/users")) PageTitle = "User Administration";
        else if (uri.EndsWith("/audit")) PageTitle = "Audit Logs";
        else if (uri.EndsWith("/review-feedback")) PageTitle = "Review Suggestions";
        else if (uri.EndsWith("/settings")) PageTitle = "System Settings";
        else if (uri.EndsWith("/feedback")) PageTitle = "Submit Feedback";
        
        StateHasChanged();
    }

    private async Task Logout()
    {
        // EXACT WPF LOGIC: Trap Clerks and Managers with Z-Reading Modal before logging out
        if (userRole == "Clerk" || userRole == "Manager")
        {
            try
            {
                // Fetch the expected cash from the backend
                ExpectedCashAmount = await Http.GetFromJsonAsync<decimal>($"api/sales/expectedcash/{currentUserId}");
            }
            catch 
            { 
                ExpectedCashAmount = 0m; 
            }

            showZReadingModal = true;
            StateHasChanged();
        }
        else
        {
            // Super-Admin and Logistics Admin skip Z-Reading
            PerformActualLogout();
        }
    }

    private async Task ProcessLogoutWithZReading(decimal actualCash)
    {
        showZReadingModal = false;

        // Note: You can add an HTTP Post here later to save 'actualCash' vs 'ExpectedCashAmount' to a ledger.
        
        PerformActualLogout();
    }

    private void PerformActualLogout()
    {
        ((CustomAuthStateProvider)AuthStateProvider).LogOut();
        Nav.NavigateTo("/login");
    }
}