@page "/discounts"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Manage Discounts | S.L.I.C.E.</PageTitle>

<div class="system-background">
    <div class="discount-grid">
        
        @* LEFT COLUMN: CREATE RULE (Matches WPF 350px Column) *@
        <div class="left-col card-style shadow-hard">
            <div class="d-flex align-items-center" style="margin-bottom: 20px;">
                <i class="fa fa-tags text-brand-orange me-2" style="font-size: 20px;"></i>
                <div class="fw-black text-dark" style="font-size: 18px;">New Pricing Rule</div>
            </div>

            <div style="margin-bottom: 15px;">
                <div class="form-label">PROMO / RULE NAME</div>
                <input type="text" class="custom-input" @bind="NewName" />
            </div>

            <div class="split-grid" style="margin-bottom: 15px;">
                <div>
                    <div class="form-label">RULE TYPE</div>
                    <select class="custom-select" @bind="NewType">
                        @foreach (var type in DiscountTypes) { <option value="@type">@type</option> }
                    </select>
                </div>
                <div>
                    <div class="form-label">REQUIRED ROLE</div>
                    <select class="custom-select" @bind="NewRole">
                        @foreach (var role in Roles) { <option value="@role">@role</option> }
                    </select>
                </div>
            </div>

            <div class="split-grid" style="margin-bottom: 25px;">
                <div>
                    <div class="form-label">VALUE TYPE</div>
                    <select class="custom-select" @bind="NewValueType">
                        @foreach (var vType in ValueTypes) { <option value="@vType">@vType</option> }
                    </select>
                </div>
                <div>
                    <div class="form-label">AMOUNT / %</div>
                    <input type="number" step="any" class="custom-input" @bind="NewValue" />
                </div>
            </div>

            <button class="btn-create" @onclick="SaveDiscount">
                <i class="fa fa-plus me-2"></i> CREATE RULE
            </button>
        </div>

        @* RIGHT COLUMN: REGISTRY DATA GRID *@
        <div class="right-col card-style shadow-hard d-flex flex-column">
            <div class="fw-black text-dark" style="font-size: 20px; margin-bottom: 20px;">Pricing Rules Registry</div>

            <div class="table-scroll-viewer flex-grow-1">
                @if (isLoading)
                {
                    <div class="text-center mt-5 text-muted"><i class="fa fa-spinner fa-spin fs-2"></i></div>
                }
                else
                {
                    <table class="custom-datagrid w-100">
                        <thead>
                            <tr>
                                <th style="width: 40%;">RULE NAME</th>
                                <th style="width: 20%;">TYPE</th>
                                <th style="width: 100px;">VALUE</th>
                                <th style="width: 120px;">REQUIRED ROLE</th>
                                <th style="width: 120px;">STATUS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in AdminDiscounts)
                            {
                                <tr>
                                    <td class="fw-bold text-dark">@item.DiscountName</td>
                                    <td>@item.DiscountType</td>
                                    <td>
                                        @if (item.ValueType == "Percentage")
                                        {
                                            <span>@item.DiscountValue.ToString("N0")%</span>
                                        }
                                        else
                                        {
                                            <span>₱@item.DiscountValue.ToString("N2")</span>
                                        }
                                    </td>
                                    <td class="text-light-custom fw-semibold">@item.RequiredRole</td>
                                    <td>
                                        <button class="btn-status @(item.IsActive ? "status-active" : "status-inactive")" 
                                                @onclick="() => ToggleStatus(item)">
                                            @if (item.IsActive)
                                            {
                                                <span>ACTIVE</span>
                                            }
                                            else
                                            {
                                                <span>INACTIVE</span>
                                            }
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* BASE SETTINGS */
    :root {
        --brand-green: #27AE60;
        --brand-orange: #E67E22;
        --brand-blue: #34495E;
        --text-dark: #2C3E50;
        --text-light: #95A5A6;
        --bg-main: #F4F6F7;
    }

    .system-background {
        background-color: var(--bg-main);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 30px;
        height: calc(100vh - 60px);
    }

    .text-dark { color: var(--text-dark); }
    .text-brand-orange { color: var(--brand-orange); }
    .text-light-custom { color: var(--text-light); }

    /* LAYOUT GRID (WPF exact mapping) */
    .discount-grid {
        display: grid;
        grid-template-columns: 350px 1fr;
        gap: 20px;
        height: 100%;
    }

    .split-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

    /* CARD STYLING */
    .card-style { background: white; border-radius: 12px; padding: 25px; }
    .shadow-hard { box-shadow: 0 4px 20px rgba(189, 195, 199, 0.2); }
    .left-col { align-self: start; }
    .right-col { overflow: hidden; min-height: 0; }

    /* FORM ELEMENTS */
    .form-label { font-size: 11px; font-weight: 700; color: var(--text-light); margin-bottom: 5px; }
    
    .custom-input, .custom-select {
        height: 40px; width: 100%; padding: 0 10px;
        border: 1px solid #BDC3C7; border-radius: 4px;
        font-size: 14px; outline: none; background: white; transition: 0.2s;
    }
    .custom-input:focus, .custom-select:focus { border-color: var(--brand-blue); }

    .btn-create {
        height: 50px; width: 100%; background: var(--brand-green); color: white;
        border: none; border-radius: 8px; font-weight: 700; font-size: 14px;
        cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; outline: none;
    }
    .btn-create:hover { filter: brightness(1.1); transform: translateY(-1px); }

    /* DATAGRID */
    .table-scroll-viewer { overflow-y: auto; padding-right: 5px; }
    .table-scroll-viewer::-webkit-scrollbar { width: 6px; }
    .table-scroll-viewer::-webkit-scrollbar-thumb { background: #BDC3C7; border-radius: 3px; }

    .custom-datagrid { border-collapse: collapse; text-align: left; }
    
    .custom-datagrid th {
        background-color: #F8F9F9; color: var(--text-light); font-size: 11px; font-weight: 700;
        padding: 10px 15px; border-bottom: 1px solid #EAECEE; position: sticky; top: 0; z-index: 1;
    }

    .custom-datagrid tr { height: 50px; transition: 0.1s; }
    .custom-datagrid tbody tr:nth-of-type(even) { background-color: #FAFCFC; }
    
    .custom-datagrid td { padding: 0 15px; border-bottom: 1px solid #ECF0F1; vertical-align: middle; color: var(--text-dark); }
    .custom-datagrid tbody tr:hover { background-color: #F0F8FF; }

    /* STATUS TOGGLE BUTTONS */
    .btn-status {
        border: none; border-radius: 4px; padding: 5px 10px;
        font-size: 11px; font-weight: 700; cursor: pointer; transition: 0.2s; width: 100px; text-align: left; outline: none;
    }
    .btn-status:hover { filter: brightness(0.95); transform: scale(1.05); }
    .status-active { background-color: #D5F5E3; color: var(--brand-green); }
    .status-inactive { background-color: #FDEDEC; color: #E74C3C; }
</style>

@code {
    private List<DiscountPayload> AdminDiscounts = new();
    private bool isLoading = true;

    private string NewName = "";
    private string NewType = "";
    private string NewValueType = "";
    private decimal NewValue = 0;
    private string NewRole = "";

    private List<string> DiscountTypes = new() { "Promo", "Manual" };
    private List<string> ValueTypes = new() { "Percentage", "Fixed" };
    private List<string> Roles = new() { "Clerk", "Manager", "Super-Admin" };

    protected override async Task OnInitializedAsync()
    {
        NewType = DiscountTypes[0];
        NewValueType = ValueTypes[0];
        NewRole = Roles[0];
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var list = await Http.GetFromJsonAsync<List<DiscountPayload>>("api/discount/admin");
            if (list != null) AdminDiscounts = list;
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error loading discounts: {ex.Message}");
        }
        isLoading = false;
    }

    private async Task SaveDiscount()
    {
        if (string.IsNullOrWhiteSpace(NewName) || NewValue <= 0)
        {
            await JS.InvokeVoidAsync("alert", "Please provide a valid name and a discount value greater than 0.");
            return;
        }

        var newDiscount = new DiscountPayload
        {
            DiscountName = NewName,
            DiscountType = NewType,
            Scope = "Order",
            ValueType = NewValueType,
            DiscountValue = NewValue,
            RequiredRole = NewRole,
            IsActive = true,
            IsStackable = false,
            // THE FIX: Dummy data injected to satisfy the strict ASP.NET Core Validation!
            Reason = "N/A", 
            ReferenceID = "N/A"
        };

        try
        {
            var response = await Http.PostAsJsonAsync("api/discount", newDiscount);
            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "Pricing rule created successfully!");
                NewName = "";
                NewValue = 0;
                await LoadData();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Validation Error: {error}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Network Error: {ex.Message}");
        }
    }

    private async Task ToggleStatus(DiscountPayload discount)
    {
        if (discount.DiscountType == "Government")
        {
            await JS.InvokeVoidAsync("alert", "Government mandated discounts (PWD/Senior) cannot be deactivated.");
            return;
        }

        try
        {
            bool newStatus = !discount.IsActive;
            var response = await Http.PutAsJsonAsync($"api/discount/{discount.DiscountID}/toggle", new { NewStatus = newStatus });
            
            if (response.IsSuccessStatusCode)
            {
                await LoadData();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"Error updating status: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Network Error: {ex.Message}");
        }
    }

    // Frontend DTO that perfectly mirrors the API requirement
    public class DiscountPayload
    {
        public int DiscountID { get; set; }
        public string DiscountName { get; set; } = string.Empty;
        public string DiscountType { get; set; } = string.Empty;
        public string Scope { get; set; } = string.Empty;
        public string ValueType { get; set; } = string.Empty;
        public decimal DiscountValue { get; set; }
        public bool IsActive { get; set; }
        public string RequiredRole { get; set; } = string.Empty;
        public bool IsStackable { get; set; }
        
        // Added properties to bypass strict backend validation
        public string Reason { get; set; } = "N/A";
        public string ReferenceID { get; set; } = "N/A";
    }
}